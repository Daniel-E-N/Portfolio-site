---
import '../styles/global.css';
import Header from '../components/Header.astro';
import CustomCursor from '../components/CustomCursor.astro';
import CanvasBackground from '../components/CanvasBackground.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  /** id of the nav item to mark as current */
  current?: 'work' | 'about' | 'contact' | 'cv';
  /** Project accent theme (preset name or custom hex), passed to the header */
  theme?: string;
}

const {
  title,
  description = 'Daniel Epler Nuñez — product designer blending UX principles, practical design skills, and thoughtful product innovation.',
  current,
  theme,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      function applyTheme() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}/favicon.png`} type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <ClientRouter />
  </head>
  <body>
    <CustomCursor />
    <CanvasBackground />
    <a class="skip-link" href="#main">Skip to content</a>
    <Header current={current} theme={theme} />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      document.addEventListener('astro:page-load', () => {
        // Smart Header: hide on scroll down, show on scroll up
        const header = document.querySelector('.site-header');
        let lastScrollY = window.scrollY;
        let downAcc = 0;

        const setHidden = (hidden: boolean) => {
          header?.classList.toggle('is-hidden', hidden);
          document.documentElement.classList.toggle('header-hidden', hidden);
        };

        let upAcc = 0;

        const onScroll = () => {
          const currentScrollY = window.scrollY;
          const delta = currentScrollY - lastScrollY;

          // Add shadow if scrolled past top
          header?.classList.toggle('is-scrolled', currentScrollY > 8);

          if (currentScrollY <= 120) {
            downAcc = 0;
            upAcc = 0;
            setHidden(false);
          } else if (delta > 0) {
            // Follow the down-scroll for a bit, then slide away
            upAcc = 0;
            downAcc += delta;
            if (downAcc > 160) setHidden(true);
          } else if (delta < 0) {
            // Snap back on any real upward intent (trackpad-friendly)
            downAcc = 0;
            upAcc += -delta;
            if (upAcc > 6) setHidden(false);
          }

          lastScrollY = currentScrollY;
        };
        
        onScroll();
        // Capture phase: fires no matter which element is the scroll container
        document.addEventListener('scroll', onScroll, { capture: true, passive: true });

        // Mobile menu
        const toggle = document.querySelector('.menu-toggle');
        const nav = document.querySelector('.site-nav');

        const closeMenu = () => {
          nav?.classList.remove('is-open');
          toggle?.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        };

        toggle?.addEventListener('click', () => {
          const isOpen = nav?.classList.contains('is-open');
          if (isOpen) {
            closeMenu();
          } else {
            nav?.classList.add('is-open');
            toggle?.setAttribute('aria-expanded', 'true');
            document.body.style.overflow = 'hidden';
          }
        });

        nav?.addEventListener('click', (e) => {
          // Close if they click the background or a link
          if (e.target === nav || e.target.closest('a')) {
            closeMenu();
          }
        });

        // Theme toggle
        const themeBtn = document.getElementById('theme-toggle');
        if (themeBtn) {
          themeBtn.addEventListener('click', () => {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            const newTheme = isDark ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
          });
        }

        // Subtle reveal-on-scroll (respects prefers-reduced-motion via CSS)
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      });
    </script>
  </body>
</html>
