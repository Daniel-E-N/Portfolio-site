---
import { linkHref, opensNewTab } from '../lib/site';
import site from '../data/site.json';

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
const text = (site.footer.text || '').replace(/\{year\}/g, String(year));
const links = (site.footer.links || []).filter((l) => l.visible !== false);
---

<footer class="site-footer">
  <div class="container">
    <p>{text}</p>
    <div class="footer-links">
      {links.map((l) => (
        <a
          href={linkHref(l, base)}
          target={opensNewTab(l) ? '_blank' : undefined}
          rel={opensNewTab(l) ? 'noopener' : undefined}
        >{l.label}</a>
      ))}
    </div>
  </div>
</footer>
