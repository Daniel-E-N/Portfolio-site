---
---
  <div class="cursor-dot"></div>
</div>
<canvas id="attractor-canvas" aria-hidden="true"></canvas>

<style>
  #attractor-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none; /* Let clicks pass through to the page */
    background: transparent;
    opacity: 0.35;
  }

  @media (hover: none) and (pointer: coarse) {
    #attractor-canvas {
      display: none !important;
    }
  }
</style>

<script>
  const CONFIG = {
    linesPerAttractor: 24,
    attractorCount: 1,
    attractionSpeed: 0.06,
    segmentLength: 16,
    segmentCount: 180,
    lineWidth: 1.5,
    friction: 0.7,
    palette: {
      positive: { hue: 170, chroma: 0.15, lightness: 60 }, // Teal brand color
      negative: { hue: 210, chroma: 0.15, lightness: 60 }  // Blue brand color
    }
  };

  let globalWiggleTime = 0;

  class Attractor {
    constructor(id, width, height, addLineCallback) {
      this.id = id;
      this.isControlledByMouse = id === 0;

      this.x = Math.random() * width;
      this.y = Math.random() * height;

      this.vx = 0;
      this.vy = 0;
      this.ax = 0;
      this.ay = 0;

      this.polarity = id % 2 === 0 ? -1 : 1;
      this.size = CONFIG.segmentLength + 1;

      this.initLines(addLineCallback);
    }

    get color() {
      return this.polarity > 0
        ? CONFIG.palette.positive
        : CONFIG.palette.negative;
    }

    initLines(addLineCallback) {
      if (this.polarity !== -1) return;

      for (let i = 0; i < CONFIG.linesPerAttractor; i++) {
        const angle = (i * 2 * Math.PI) / CONFIG.linesPerAttractor;
        const offsetX = Math.cos(angle);
        const offsetY = Math.sin(angle);
        addLineCallback(this, offsetX, offsetY);
      }
    }

    calculateForces(attractors, maxDistance) {
      for (const other of attractors) {
        if (other === this) continue;

        const dx = other.x - this.x;
        const dy = other.y - this.y;
        const distance = Math.hypot(dx, dy);

        if (distance >= maxDistance) continue;

        const isSamePolarity =
          (this.polarity > 0 && other.polarity > 0) ||
          (this.polarity < 0 && other.polarity < 0);
        const attractionForce = isSamePolarity ? -10 : 10;

        const inverseDistance = maxDistance - distance;
        const angle = Math.atan2(dy, dx);

        const forceScale =
          (maxDistance * maxDistance) / (inverseDistance * inverseDistance);
        const magnitude =
          distance > this.size * 2
            ? (attractionForce * CONFIG.attractionSpeed) / forceScale
            : (-1 * CONFIG.attractionSpeed) / forceScale;

        this.ax += magnitude * Math.cos(angle);
        this.ay += magnitude * Math.sin(angle);
      }
    }

    update(pointer, width, height) {
      if (this.isControlledByMouse) {
        // Smoothly lerp towards the cursor for a fluid, dragging effect
        this.x += (pointer.x - this.x) * 0.15;
        this.y += (pointer.y - this.y) * 0.15;

        if (pointer.isDown && !pointer.wasDownChecked) {
          this.polarity *= -1;
          pointer.wasDownChecked = true;
        }
        if (!pointer.isDown) {
          pointer.wasDownChecked = false;
        }
        return;
      }

      this.vx = (this.vx + this.ax) * CONFIG.friction;
      this.vy = (this.vy + this.ay) * CONFIG.friction;
      this.x += this.vx;
      this.y += this.vy;

      this.ax = 0;
      this.ay = 0;

      this.handleBoundaries(width, height);
    }

    handleBoundaries(width, height) {
      if (this.x < this.size) {
        this.x += this.size - this.x;
        this.vx *= -1;
      } else if (this.x > width - this.size) {
        this.x -= this.x - width + this.size;
        this.vx *= -1;
      }

      if (this.y < this.size) {
        this.y += this.size - this.y;
        this.vy *= -1;
      } else if (this.y > height - this.size) {
        this.y -= this.y - height + this.size;
        this.vy *= -1;
      }
    }

    render(ctx) {
      if (!this.isControlledByMouse) return;

      const { lightness, chroma, hue } = this.color;

      // Only draw the inner dense part of the gradient, omitting the massive outer rings
      for (let i = 0; i < 6; i++) {
        const radiusScale = Math.pow(i / 4, 3);
        const alpha = Math.pow(1 - i / 10, 2);

        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size * radiusScale, 0, 2 * Math.PI);
        ctx.fillStyle = `oklch(${lightness}% ${chroma} ${hue} / ${alpha})`;
        ctx.fill();
      }
    }
  }

  class VectorLine {
    constructor(parent, offsetX, offsetY) {
      this.parent = parent;
      this.offsetX = offsetX;
      this.offsetY = offsetY;
      this.tail = [];
      this.reset();
    }

    reset() {
      this.x = this.parent.x + this.offsetX;
      this.y = this.parent.y + this.offsetY;
      this.tail = [
        { x: this.parent.x, y: this.parent.y },
        { x: this.x, y: this.y }
      ];
    }

    update(attractors) {
      this.tail = [];

      for (let i = 0; i < CONFIG.segmentCount; i++) {
        let shouldEarlyExit = false;
        let vx = 0;
        let vy = 0;

        for (const attractor of attractors) {
          const dx = (attractor.x - this.x) * attractor.polarity;
          const dy = (attractor.y - this.y) * attractor.polarity;
          const distance = Math.hypot(dx, dy) || 0.001;

          if (distance < CONFIG.segmentLength * 1.2 && attractor.polarity === 1) {
            shouldEarlyExit = true;
          }

          const squaredDistance = distance * distance;
          vx += dx / squaredDistance;
          vy += dy / squaredDistance;
        }

        // Add an organic wiggle to the lines based on cursor movement speed
        const wiggleAngle = Math.sin(globalWiggleTime - i * 0.1) * 0.25;
        const baseAngle = Math.atan2(vy, vx);
        const finalAngle = baseAngle + wiggleAngle;

        this.x += Math.cos(finalAngle) * CONFIG.segmentLength;
        this.y += Math.sin(finalAngle) * CONFIG.segmentLength;

        this.tail.push({ x: this.x, y: this.y });

        if (shouldEarlyExit) break;
      }
    }

    render(ctx) {
      if (this.tail.length === 0) return;

      ctx.beginPath();
      ctx.moveTo(this.tail[0].x, this.tail[0].y);

      for (let i = 1; i < this.tail.length; i++) {
        ctx.lineTo(this.tail[i].x, this.tail[i].y);
      }

      // Slightly teal/blue tinted lines with low opacity for the light background
      ctx.strokeStyle = "oklch(60% 0.05 190 / 0.15)";
      ctx.lineWidth = CONFIG.lineWidth;
      ctx.stroke();
    }
  }

  class Simulation {
    constructor(canvas) {
      this.canvas = canvas;
      this.ctx = this.canvas.getContext("2d");

      this.width = 0;
      this.height = 0;
      this.maxDistance = 0;

      this.attractors = [];
      this.lines = [];

      this.pointer = { x: window.innerWidth / 2, y: window.innerHeight / 2, isDown: false, wasDownChecked: false };

      this.initDimensions();
      this.initEntities();
      this.initEventListeners();

      this.isRunning = true;
      this.loop = this.loop.bind(this);
      this.animationFrame = requestAnimationFrame(this.loop);
    }

    initDimensions() {
      this.width = this.canvas.width = window.innerWidth;
      this.height = this.canvas.height = window.innerHeight;
      this.maxDistance = Math.hypot(this.width, this.height);
    }

    initEntities() {
      const addLine = (parent, x, y) =>
        this.lines.push(new VectorLine(parent, x, y));

      for (let i = 0; i < CONFIG.attractorCount; i++) {
        this.attractors.push(new Attractor(i, this.width, this.height, addLine));
      }
    }

    initEventListeners() {
      this.onResize = () => this.initDimensions();
      window.addEventListener("resize", this.onResize);

      this.onMouseMove = (e) => {
        this.pointer.x = e.clientX;
        this.pointer.y = e.clientY;
      };
      window.addEventListener("mousemove", this.onMouseMove);

      this.onMouseDown = () => (this.pointer.isDown = true);
      window.addEventListener("mousedown", this.onMouseDown);
      
      this.onMouseUp = () => (this.pointer.isDown = false);
      window.addEventListener("mouseup", this.onMouseUp);

      this.onTouchMove = (e) => {
        if (window.matchMedia('(hover: none)').matches) return;
        if (e.touches.length === 0) return;
        this.pointer.x = e.touches[0].clientX;
        this.pointer.y = e.touches[0].clientY;
      };
      window.addEventListener("touchmove", this.onTouchMove, { passive: true });
      
      this.onTouchStart = () => {
        if (window.matchMedia('(hover: none)').matches) return;
        this.pointer.isDown = true;
      };
      window.addEventListener("touchstart", this.onTouchStart, { passive: true });
      
      this.onTouchEnd = () => {
        if (window.matchMedia('(hover: none)').matches) return;
        this.pointer.isDown = false;
      };
      window.addEventListener("touchend", this.onTouchEnd);

      this.onScroll = () => {
        if (window.matchMedia('(hover: none)').matches) {
          const scrollY = window.scrollY;
          const maxScroll = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
          const scrollPercent = scrollY / maxScroll;
          
          this.pointer.y = window.innerHeight * scrollPercent;
          this.pointer.x = window.innerWidth / 2 + Math.sin(scrollPercent * Math.PI * 4) * (window.innerWidth * 0.4);
        }
      };
      window.addEventListener("scroll", this.onScroll, { passive: true });
    }

    destroy() {
      this.isRunning = false;
      cancelAnimationFrame(this.animationFrame);
      window.removeEventListener("resize", this.onResize);
      window.removeEventListener("mousemove", this.onMouseMove);
      window.removeEventListener("mousedown", this.onMouseDown);
      window.removeEventListener("mouseup", this.onMouseUp);
      window.removeEventListener("touchmove", this.onTouchMove);
      window.removeEventListener("touchstart", this.onTouchStart);
      window.removeEventListener("touchend", this.onTouchEnd);
      window.removeEventListener("scroll", this.onScroll);
    }

    loop() {
      if (!this.isRunning) return;

      const dx = this.pointer.x - (this.lastPointerX ?? this.pointer.x);
      const dy = this.pointer.y - (this.lastPointerY ?? this.pointer.y);
      const speed = Math.hypot(dx, dy);
      
      this.lastPointerX = this.pointer.x;
      this.lastPointerY = this.pointer.y;
      
      globalWiggleTime += Math.min(speed * 0.005, 0.2); // Only progress the sine wave when moving

      this.ctx.clearRect(0, 0, this.width, this.height);

      for (const line of this.lines) {
        line.reset();
        line.update(this.attractors);
        line.render(this.ctx);
      }

      for (const attractor of this.attractors) {
        attractor.calculateForces(this.attractors, this.maxDistance);
        attractor.update(this.pointer, this.width, this.height);
      }

      for (const attractor of this.attractors) {
        attractor.render(this.ctx);
      }

      this.animationFrame = requestAnimationFrame(this.loop);
    }
  }

  let activeSimulation = null;

  function init() {
    if (window.matchMedia('(hover: none) and (pointer: coarse)').matches) return;
    
    const canvas = document.getElementById("attractor-canvas");
    if (canvas) {
      if (activeSimulation) {
        activeSimulation.destroy();
      }
      activeSimulation = new Simulation(canvas);
    }
  }

  // Handle initialization on page load and View Transitions
  document.addEventListener("astro:page-load", init);
  
  // Cleanup to prevent memory leaks when navigating away
  document.addEventListener("astro:before-swap", () => {
    if (activeSimulation) {
      activeSimulation.destroy();
      activeSimulation = null;
    }
  });
</script>
