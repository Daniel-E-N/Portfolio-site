---
/**
 * Sitewide custom cursor (extracted from CanvasBackground so every page
 * gets the same cursor without carrying the canvas simulation).
 */
---

<svg xmlns="http://www.w3.org/2000/svg" role="presentation" style="display: none">
  <filter id="glass-distortion" x="0%" y="0%" width="100%" height="100%" filterUnits="objectBoundingBox">
    <feTurbulence type="fractalNoise" baseFrequency="0.05" numOctaves="1" seed="17" result="turbulence"/>
    <feComponentTransfer in="turbulence" result="mapped">
      <feFuncR type="gamma" amplitude="1" exponent="10" offset="0.5" />
      <feFuncG type="gamma" amplitude="0" exponent="1" offset="0" />
      <feFuncB type="gamma" amplitude="0" exponent="1" offset="0.5" />
    </feComponentTransfer>
    <feGaussianBlur in="turbulence" stdDeviation="3" result="softMap" />
    <feSpecularLighting in="softMap" surfaceScale="5" specularConstant="1" specularExponent="100" lighting-color="white" result="specLight">
      <fePointLight x="-200" y="-200" z="300" />
    </feSpecularLighting>
    <feComposite in="specLight" operator="arithmetic" k1="0" k2="1" k3="1" k4="0" result="litImage" />
    <feDisplacementMap in="SourceGraphic" in2="softMap" scale="20" xChannelSelector="R" yChannelSelector="G" />
  </filter>
</svg>
<div id="custom-cursor">
  <div class="cursor-glass"></div>
  <div class="cursor-dot"></div>
</div>

<style>
  @media (pointer: fine) {
    :global(*) {
      cursor: none !important;
    }
  }

  #custom-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: transparent;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.3s, width 0.2s, height 0.2s;
    will-change: transform;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (hover: none) and (pointer: coarse) {
    #custom-cursor {
      display: none !important;
    }
  }

  /* Solid dot */
  .cursor-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #000;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 10;
    transform: translate(-50%, -50%) translateZ(1px);
  }

  .cursor-dot::before,
  .cursor-dot::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    background: inherit;
    width: 0px;
    height: 2px;
    border-radius: 1px;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .cursor-dot::before { top: 0; }
  .cursor-dot::after { bottom: 0; }

  #custom-cursor.is-hovering .cursor-dot {
    background: #000;
  }

  #custom-cursor.is-text .cursor-dot {
    width: 2px;
    height: 22px;
    border-radius: 1px;
    background: #000;
    transform: translate(-50%, -50%) translateZ(1px);
  }

  #custom-cursor.is-text .cursor-dot::before,
  #custom-cursor.is-text .cursor-dot::after {
    width: 8px;
  }

  #custom-cursor.is-text .cursor-glass {
    opacity: 0.4;
  }

  /* Glass halo */
  .cursor-glass {
    position: absolute;
    width: 60px;
    height: 60px;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
    box-shadow: 0 0 12px rgba(255, 255, 255, 0.3), 0 2px 8px rgb(0 0 0 / 5%);
    border: 1px solid rgba(255, 255, 255, 0.4);
    transform: translate(-50%, -50%) scale(0.6);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), background 0.3s, box-shadow 0.3s, border 0.3s;
    z-index: 1;
  }

  .cursor-glass::before,
  .cursor-glass::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 1;
    transition: opacity 0.4s;
  }

  .cursor-glass::before {
    backdrop-filter: blur(3px);
    filter: url(#glass-distortion);
    z-index: -1;
  }

  .cursor-glass::after {
    box-shadow: inset 1px 1px 1px 0 rgb(255 255 255 / 25%), inset -1px -1px 1px 0 rgb(255 255 255 / 10%);
  }

  #custom-cursor.is-hovering {
    width: 24px;
    height: 24px;
  }

  #custom-cursor.is-hovering .cursor-glass {
    transform: translate(-50%, -50%) scale(1);
    background: color-mix(in srgb, rgba(255, 255, 255, 0.8) 25%, transparent);
    box-shadow: 0 6px 6px rgb(0 0 0 / 20%), 0 0 20px rgb(0 0 0 / 10%), 0 0 15px rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  #custom-cursor.is-hovering .cursor-glass::before,
  #custom-cursor.is-hovering .cursor-glass::after {
    opacity: 1;
  }
</style>

<script>
  // One persistent listener; the cursor element is re-queried per event so
  // it keeps working across Astro view transitions.
  const w = window as any;
  if (!w.__customCursorAttached) {
    w.__customCursorAttached = true;

    window.addEventListener('mousemove', (e) => {
      const cursor = document.getElementById('custom-cursor');
      const t = e.target instanceof Element ? e.target : null;
      if (!cursor || !t) return;

      cursor.style.opacity = '1';
      cursor.style.transform = `translate(calc(${e.clientX}px - 50%), calc(${e.clientY}px - 50%))`;

      // Theme detection (always on)
      const themeWrapper = t.closest('[data-theme]');
      if (themeWrapper) {
        cursor.setAttribute('data-theme', themeWrapper.getAttribute('data-theme') || '');
      } else {
        cursor.removeAttribute('data-theme');
      }

      // Hover detection (interactive elements)
      const hoveredEl = t.closest('a, button, [role="button"], input, select, textarea, summary');
      if (hoveredEl) {
        cursor.classList.add('is-hovering');
      } else {
        cursor.classList.remove('is-hovering');
      }

      // Hover detection (text elements)
      let isTextHover = false;
      const textEl = t.closest('p, h1, h2, h3, h4, h5, h6, li, blockquote, figcaption, label, time, span, strong, em');
      if (textEl && !hoveredEl) {
        const walker = document.createTreeWalker(textEl, NodeFilter.SHOW_TEXT, null);
        let textNode;
        while ((textNode = walker.nextNode())) {
          if (!textNode.textContent || textNode.textContent.trim().length === 0) continue;
          const r = document.createRange();
          r.selectNodeContents(textNode);
          const rects = r.getClientRects();
          for (let i = 0; i < rects.length; i++) {
            const rect = rects[i];
            if (
              e.clientX >= rect.left - 6 && e.clientX <= rect.right + 6 &&
              e.clientY >= rect.top - 6 && e.clientY <= rect.bottom + 6
            ) {
              isTextHover = true;
              break;
            }
          }
          if (isTextHover) break;
        }
      }
      cursor.classList.toggle('is-text', isTextHover);
    });
  }
</script>
