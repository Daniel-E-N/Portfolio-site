---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import cv from '../data/cv.json';

/**
 * Interactive CV — content is managed in src/data/cv.json via the CMS
 * ("Interactive CV" tab, tools/cms.mjs). This page derives its display
 * arrays from that data and keeps the original structure, styling and
 * filtering behaviour.
 *
 * cats: focus-theme ids — used by the Focus bar (dims, never hides).
 * Chip `roles` reference experience/education ids — selecting skills
 * (multi-select) highlights the connected entries below.
 */

const byOrder = (a: any, b: any) => (a.order ?? 99) - (b.order ?? 99);
const vis = (x: any) => x.visible !== false;
const compose = (a: string, b?: string) => (b ? `${a} · ${b}` : a);
const range = (s: string, e: string, current?: boolean) =>
  current ? `${s} – Present` : e ? `${s} – ${e}` : s;

const profile = cv.profile;
const pdf = cv.pdf as { file: string } | null;

/* project slug → title, pulled from the real projects collection (no duplication) */
const projectEntries = await getCollection('projects');
const projectTitle = new Map(projectEntries.map((e) => [e.id.split('/')[0], e.data.title]));

const focusThemes = [...cv.focusThemes].filter(vis).sort(byOrder);
const filters = [{ id: 'all', label: 'Everything' }, ...focusThemes.map((t) => ({ id: t.id, label: t.label }))];

const roles = [...cv.experience].filter(vis).sort(byOrder).map((r) => ({
  id: r.id,
  title: r.title,
  org: compose(r.org, r.city),
  dates: range(r.start, r.end, r.current),
  cats: r.themes || [],
  summary: r.summary,
  bullets: r.bullets || [],
  details: r.details && r.details.length ? r.details : undefined,
}));

const education = [...cv.education].filter(vis).sort(byOrder).map((e) => ({
  id: e.id,
  title: e.title,
  org: compose(e.institution, e.city),
  dates: range(e.start, e.end, e.current),
  note: e.note,
  body: e.body,
}));

const skillsByCat = new Map<string, any[]>();
for (const s of [...cv.skills].filter(vis).sort(byOrder)) {
  if (!skillsByCat.has(s.category)) skillsByCat.set(s.category, []);
  skillsByCat.get(s.category)!.push(s);
}
const skillGroups = [...cv.skillCategories].filter(vis).sort(byOrder).map((c) => ({
  name: c.name,
  cats: c.themes || [],
  chips: (skillsByCat.get(c.id) || []).map((s) => {
    const ids = [...(s.relatedRoles || []), ...(s.relatedEducation || [])];
    return ids.length ? { label: s.name, roles: ids } : { label: s.name };
  }),
}));

const projects = [...cv.projects].filter(vis).sort(byOrder).map((p) => ({
  title: projectTitle.get(p.slug) || p.slug,
  slug: p.slug,
}));
---

<BaseLayout
  title={profile.pageTitle}
  description={profile.metaDescription}
  current="cv"
>
  <div class="cv-page" data-filter="all">
    <!-- Hero -->
    <section class="page-hero container">
      <h1>{profile.heading}</h1>
      <p class="lede">{profile.lede}</p>
      <ul class="cv-facts" aria-label="Quick facts">
        {profile.facts.map((f) => <li>{f}</li>)}
      </ul>
      <div class="cv-actions">
        {pdf ? (
          <a class="btn btn--solid" href={`${import.meta.env.BASE_URL}/${pdf.file}`} download>{profile.downloadLabel} <span class="arrow">↓</span></a>
        ) : (
          <button class="btn btn--solid" id="cv-print">{profile.downloadLabel} <span class="arrow">↓</span></button>
        )}
        <a class="btn" href={`mailto:${profile.email}?subject=From%20your%20CV%20page`}>Email me <span class="arrow">→</span></a>
      </div>
    </section>

    <!-- Focus bar (sticky) -->
    <div class="cv-filter-wrap">
      <div class="container">
        <div class="cv-filter" role="group" aria-label="Highlight CV by focus area">
          <span class="cv-filter-label">Focus</span>
          {filters.map((f) => (
            <button class="cv-filter-btn" data-filter-id={f.id} aria-pressed={f.id === 'all' ? 'true' : 'false'}>
              {f.label}
            </button>
          ))}
        </div>
      </div>
    </div>

    <div class="container">
      <div class="cv-wrap">
        <!-- Skills: dropdown groups + multi-select highlighting -->
        <section class="cv-skillmenu" aria-label="Skills and competencies">
          <div class="cv-skillmenu-head">
            <h2 class="cv-h2">Skills</h2>
            <p class="cv-status" role="status" aria-live="polite">
              <span id="cv-status-text">Select skills to highlight where I used them — combine as many as you like.</span>
              <button id="cv-clear" class="cv-clear" hidden>Clear ×</button>
            </p>
          </div>
          {skillGroups.map((g) => (
            <details class="cv-skill-group" data-cats={g.cats.join(' ')}>
              <summary>
                <span class="group-name">{g.name}</span>
                <span class="group-meta">{g.chips.length} skills</span>
              </summary>
              <div class="cv-skills">
                {g.chips.map((c) =>
                  c.roles ? (
                    <button class="cv-chip" data-roles={c.roles.join(' ')} aria-pressed="false">
                      {c.label}
                      <span class="chip-count" aria-label={`${c.roles.length} connections`}>{c.roles.length}</span>
                    </button>
                  ) : (
                    <span class="cv-chip cv-chip--static">{c.label}</span>
                  )
                )}
              </div>
            </details>
          ))}
        </section>

        <!-- Experience -->
        <h2 class="cv-h2">Experience</h2>
        <div class="cv-timeline">
          {roles.map((r) => (
            <article class="cv-role" id={`role-${r.id}`} data-cats={r.cats.join(' ')}>
              <header class="cv-role-head">
                <h3>{r.title}</h3>
                <p class="cv-org">{r.org}</p>
                <p class="cv-dates">{r.dates}</p>
              </header>
              <p class="cv-summary">{r.summary}</p>
              <ul class="cv-bullets">
                {r.bullets.map((b) => <li>{b}</li>)}
              </ul>
              {r.details && (
                <details class="cv-more">
                  <summary>More detail</summary>
                  <ul class="cv-bullets">
                    {r.details.map((b) => <li>{b}</li>)}
                  </ul>
                </details>
              )}
            </article>
          ))}
        </div>

        <!-- Education -->
        <h2 class="cv-h2">Education</h2>
        <div class="cv-timeline">
          {education.map((e) => (
            <article class="cv-role cv-edu" id={`role-${e.id}`}>
              <header class="cv-role-head">
                <h3>{e.title}</h3>
                <p class="cv-org">{e.org}</p>
                <p class="cv-dates">{e.dates}</p>
              </header>
              <p class="cv-note">{e.note}</p>
              <p class="cv-summary">{e.body}</p>
            </article>
          ))}
        </div>

        <!-- Selected work -->
        <h2 class="cv-h2">Selected work</h2>
        <ul class="cv-projects">
          {projects.map((p) => (
            <li>
              <a href={`${import.meta.env.BASE_URL}/portfolio/${p.slug}`}>{p.title} <span class="arrow" aria-hidden="true">→</span></a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('astro:page-load', () => {
      const page = document.querySelector<HTMLElement>('.cv-page');
      if (!page) return;

      // --- Print / PDF (property assignment: safe across page swaps) ---
      document.getElementById('cv-print')?.addEventListener('click', () => window.print());
      window.onbeforeprint = () => {
        page.querySelectorAll<HTMLDetailsElement>('details').forEach((d) => {
          if (!d.open) { d.dataset.autoOpened = 'true'; d.open = true; }
        });
      };
      window.onafterprint = () => {
        page.querySelectorAll<HTMLDetailsElement>('details[data-auto-opened]').forEach((d) => {
          d.open = false;
          delete d.dataset.autoOpened;
        });
      };

      // --- Focus filter (dims, never hides) ---
      const filterBtns = page.querySelectorAll<HTMLButtonElement>('.cv-filter-btn');
      filterBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          page.dataset.filter = btn.dataset.filterId || 'all';
          filterBtns.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        });
      });

      // --- Skills: multi-select → highlight connected entries, no scrolling ---
      const chips = Array.from(page.querySelectorAll<HTMLButtonElement>('.cv-chip[data-roles]'));
      const statusText = document.getElementById('cv-status-text');
      const clearBtn = document.getElementById('cv-clear') as HTMLButtonElement | null;
      const defaultStatus = statusText?.textContent || '';
      const selected = new Set<HTMLButtonElement>();

      const update = () => {
        page.querySelectorAll('.cv-role.is-hit').forEach((el) => el.classList.remove('is-hit'));
        if (selected.size === 0) {
          page.classList.remove('is-xhl');
          if (statusText) statusText.textContent = defaultStatus;
          if (clearBtn) clearBtn.hidden = true;
          return;
        }
        const ids = new Set<string>();
        selected.forEach((chip) =>
          (chip.dataset.roles || '').split(' ').forEach((id) => id && ids.add(id))
        );
        let hits = 0;
        ids.forEach((id) => {
          const el = document.getElementById(`role-${id}`);
          if (el) { el.classList.add('is-hit'); hits++; }
        });
        page.classList.add('is-xhl');
        if (statusText) {
          const s = selected.size;
          statusText.textContent = `${s} skill${s > 1 ? 's' : ''} selected → ${hits} ${hits === 1 ? 'entry' : 'entries'} highlighted below`;
        }
        if (clearBtn) clearBtn.hidden = false;
      };

      const clearAll = () => {
        selected.forEach((c) => { c.classList.remove('is-active'); c.setAttribute('aria-pressed', 'false'); });
        selected.clear();
        update();
      };

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          if (selected.has(chip)) {
            selected.delete(chip);
            chip.classList.remove('is-active');
            chip.setAttribute('aria-pressed', 'false');
          } else {
            selected.add(chip);
            chip.classList.add('is-active');
            chip.setAttribute('aria-pressed', 'true');
          }
          update();
        });
      });
      clearBtn?.addEventListener('click', clearAll);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && selected.size) clearAll();
      });
    });
  </script>
</BaseLayout>
