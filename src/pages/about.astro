---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { linkHref, opensNewTab, emphasize } from '../lib/site';
import site from '../data/site.json';

const base = import.meta.env.BASE_URL;
const about = site.about;

const assetModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/*.{png,jpg,jpeg,webp,gif,avif}',
  { eager: true }
);
const img = (name?: string) => (name ? assetModules[`../assets/${name}`]?.default : undefined);

const portrait = img(about.portrait?.src);
const buttons = (about.buttons || []).filter((b) => b.visible !== false);
const stripPhotos = (about.photoStrip?.photos || []).filter((p) => img(p.src));
const showStrip = about.photoStrip?.visible !== false && stripPhotos.length > 0;
---

<BaseLayout title={about.metaTitle || `About — ${site.identity.siteName}`} current="about">
  <section class="page-hero container">
    <h1>{about.hero.heading}</h1>
    <p class="lede">{about.hero.lede}</p>
    {(about.hero.facts || []).length > 0 && (
      <ul class="cv-facts" aria-label="Quick facts">
        {about.hero.facts.map((f) => <li>{f}</li>)}
      </ul>
    )}
  </section>

  <section class="container" style="padding-bottom: var(--space-6);">
    <div class="about-grid">
      {portrait && (
        <div class="portrait">
          <Image src={portrait} alt={about.portrait.alt || ''} widths={[480, 960]} sizes="(max-width: 880px) 22rem, 420px" />
        </div>
      )}
      <div class="about-body">
        {(about.paragraphs || []).map((p) => (
          <p set:html={emphasize(p)} />
        ))}

        {(about.skills || []).length > 0 && (
          <h2 style="font-size: var(--step-2); margin: var(--space-4) 0 var(--space-2);">{about.skillsHeading}</h2>
        )}
        {(about.skills || []).length > 0 && (
          <ul class="skills">
            {about.skills.map((s) => <li>{s}</li>)}
          </ul>
        )}

        {buttons.length > 0 && (
          <div class="hero-actions" style="margin-top: var(--space-3);">
            {buttons.map((b) => (
              <a
                class={b.style === 'solid' ? 'btn btn--solid' : 'btn'}
                href={linkHref(b, base)}
                target={opensNewTab(b) ? '_blank' : undefined}
                rel={opensNewTab(b) ? 'noopener' : undefined}
              >{b.label} {b.arrow && <span class="arrow">{b.arrow}</span>}</a>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  {showStrip && (
    <section class="container" style="padding-bottom: var(--space-6);">
      <div class="photo-strip reveal" style={`grid-template-columns: repeat(${stripPhotos.length}, 1fr);`}>
        {stripPhotos.map((p) => (
          <Image src={img(p.src)!} alt={p.alt || ''} widths={[400]} sizes="280px" />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
