  <section class="container" style="padding-bottom: var(--space-6);">
    <ul class="contact-list">
      <li>
        <a href="mailto:danielepler93@gmail.com?subject=From%20daniel-epler-nunez.com">
          <span class="label">Email</span>
          <span class="value">danielepler93@gmail.com</span>
          <span class="arrow" aria-hidden="true">↗</span>
        </a>
      </li>
      <li>
        <a href="https://www.linkedin.com/in/danieleplernunez/" target="_blank" rel="noopener">
          <span class="label">LinkedIn</span>
          <span class="value">danieleplernunez</span>
          <span class="arrow" aria-hidden="true">↗</span>
        </a>
      </li>
      <li>
        <a href="tel:+4527639685">
