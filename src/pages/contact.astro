---
import BaseLayout from '../layouts/BaseLayout.astro';
import { linkHref, opensNewTab } from '../lib/site';
import site from '../data/site.json';

const base = import.meta.env.BASE_URL;
const contact = site.contact;
const links = (contact.links || []).filter((l) => l.visible !== false);
const arrowOf = (l: { kind?: string }) => (l.kind === 'internal' ? '→' : '↗');
---

<BaseLayout title={contact.metaTitle || `Contact — ${site.identity.siteName}`} current="contact">
  <section class="page-hero container">
    <h1>{contact.hero.heading}</h1>
    <p class="lede">{contact.hero.lede}</p>
    {(contact.hero.facts || []).length > 0 && (
      <ul class="cv-facts" aria-label="Quick facts">
        {contact.hero.facts.map((f) => <li>{f}</li>)}
      </ul>
    )}
  </section>

  <section class="container" style="padding-bottom: var(--space-6);">
    <ul class="contact-list">
      {links.map((l) => (
        <li>
          <a
            href={linkHref(l, base)}
            target={opensNewTab(l) ? '_blank' : undefined}
            rel={opensNewTab(l) ? 'noopener' : undefined}
          >
            <span class="label">{l.label}</span>
            <span class="value">{l.value}</span>
            <span class="arrow" aria-hidden="true">{arrowOf(l)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
